# Copy to scripts/.env.spike and fill in. scripts/.env.spike is gitignored.
# Funded relayer-side key. NEVER commit.
VIBETRACE_0G_COMPUTE_PRIVATE_KEY=0x...
# 0G testnet RPC. chainId 16602 = SDK TESTNET_CHAIN_ID.
VIBETRACE_0G_COMPUTE_RPC_URL=https://evmrpc-testnet.0g.ai
VIBETRACE_0G_COMPUTE_CHAIN_ID=16602
# Optional: pin a provider/model. Leave unset to auto-discover the first acknowledged TeeML provider.
VIBETRACE_0G_COMPUTE_PROVIDER=
VIBETRACE_0G_COMPUTE_MODEL=
