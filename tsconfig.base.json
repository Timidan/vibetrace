{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "paths": {
      "@vibetrace/schema": ["packages/schema/src/index.ts"],
      "@vibetrace/graph": ["packages/graph/src/index.ts"],
      "@vibetrace/og": ["packages/og/src/index.ts"],
      "@vibetrace/verifier": ["packages/verifier/src/index.ts"],
      "@vibetrace/score": ["packages/score/src/index.ts"]
    }
  }
}
