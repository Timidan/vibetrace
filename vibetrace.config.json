{
  "schemaVersion": "vibetrace.config.v1",
  "project": {
    "name": "vibetrace",
    "description": "Local-first proof-of-build ledger for AI-assisted software."
  },
  "privacy": {
    "redaction": "private-by-default"
  },
  "snapshot": {
    "ignore": [
      ".git/**",
      ".vibetrace/**",
      "node_modules/**",
      "dist/**",
      ".next/**",
      "coverage/**",
      "playwright-report/**",
      "test-results/**",
      ".env*",
      "*.log",
      "**/node_modules/**/*",
      "**/dist/*",
      "**/dist/**/*",
      "**/*.tsbuildinfo",
      "**/.vite/**/*"
    ]
  },
  "traces": {
    "include": [
      ".agenttrace/*.json",
      ".agenttrace/**/*.json",
      ".vibetrace/inbox/*.json",
      ".vibetrace/inbox/**/*.json",
      "agenttrace/*.json",
      "agenttrace/**/*.json",
      "ai-traces/*.json",
      "ai-traces/**/*.json",
      "trace.json",
      "traces/*.json",
      "traces/**/*.json",
      "vibetrace.trace.json",
      "fixtures/vibetrace-session-trace.json"
    ]
  },
  "publish": {
    "publicBundlePath": "public/vibetrace.json"
  }
}
