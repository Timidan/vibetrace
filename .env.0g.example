# Real 0G anchoring — copy this file to `.env.0g` and fill in a FUNDED,
# THROWAWAY testnet key. Never use a mainnet key. `.env.0g` is gitignored.
#
# Get test OG tokens for the Galileo testnet from the faucet:
#   https://faucet.0g.ai   (chain: 0G-Galileo-Testnet, id 16602)
#
# Then anchor for real with:
#   set -a; . ./.env.0g; set +a
#   pnpm build && node apps/cli/dist/vibetrace.mjs   # bare one-shot: collect -> publish -> register
#
# Mode options:
#   real-chain  → real on-chain tx (the explorer link) + local dev storage  [recommended, minimal]
#   real        → real on-chain tx AND real 0G Storage upload (needs storage indexer)

VIBETRACE_OG_MODE=real-chain
VIBETRACE_0G_PRIVATE_KEY=0xREPLACE_WITH_FUNDED_TESTNET_KEY
VIBETRACE_0G_RPC_URL=https://evmrpc-testnet.0g.ai
VIBETRACE_0G_CHAIN_ID=16602
